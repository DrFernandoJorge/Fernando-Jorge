# ======================================================================
# EXEMPLO de variáveis de ambiente. Copie para `.env` e preencha.
# NUNCA commite o arquivo .env real (ele está no .gitignore).
# ======================================================================

# --- Supabase (pegue em: Project Settings > API) ---
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_ANON_KEY="chave-anon-publica"
# service_role tem acesso total e IGNORA o RLS. Use SÓ no backend/serviços.
# Nunca exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY="chave-service-role-secreta"

# --- Frontend (Next.js na Vercel) ---
# Só variáveis NEXT_PUBLIC_* vão para o navegador. Nunca coloque segredos aqui.
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="chave-anon-publica"
